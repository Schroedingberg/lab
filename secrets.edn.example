;; Secrets for lab-orchestrator
;; Copy this file to secrets.edn and fill in your values
;; secrets.edn is gitignored

{;; For simple HTTP integrations
 :mealie-url "https://mealie.your-domain.com"
 :mealie-token "your-api-token-here"
 
 ;; Structured secrets for code-based integrations
 :mealie {:url "https://mealie.your-domain.com"
          :token "your-api-token-here"}
 
 :vikunja {:url "https://vikunja.your-domain.com"
           :token "your-api-token-here"}}
